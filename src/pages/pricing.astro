---
import Layout from '../layouts/Layout.astro';
---

<style is:global>
  .pricing-table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .pricing-table-inner { min-width: 560px; }
  .pricing-included-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; max-width: 900px; margin: 0 auto; }
  @media (max-width: 700px) {
    .pricing-included-grid { grid-template-columns: 1fr !important; gap: 20px !important; }
    .pricing-hero-padding { padding: 48px 20px 40px !important; }
    .pricing-section-padding { padding-top: 48px !important; padding-bottom: 48px !important; }
  }
</style>

<Layout title="Pricing" description="Transparent vehicle transport pricing from Tow It. No hidden fees, no bidding, no surprises. See exactly how our pricing works and get an instant quote on WhatsApp.">

  <!-- HERO -->
  <section class="pricing-hero-padding" style="background:linear-gradient(135deg,#080C14 0%,#0E1421 100%);padding:80px 24px 60px;text-align:center;position:relative;overflow:hidden;">
    <img src="/images/pricing-motorway.jpg" alt="" style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;opacity:0.1;pointer-events:none;z-index:0;" />
    <div style="max-width:700px;margin:0 auto;position:relative;z-index:1;">
      <p style="color:#00C2FF;font-size:0.875rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:12px;">Transparent Pricing</p>
      <h1 style="font-size:clamp(2rem,5vw,3.5rem);font-weight:900;color:#ffffff;margin-bottom:20px;line-height:1.1;">No hidden fees.<br><span style="color:#00C2FF;">Ever.</span></h1>
      <p style="color:#8B96A8;font-size:1.1rem;line-height:1.7;max-width:560px;margin:0 auto 40px;">The price you're quoted is the price you pay. No bidder fees, no buyer protection charges, no platform surcharges. What our AI quotes, you pay — full stop.</p>
      <button onclick="openWaitlistModal()" style="display:inline-flex;align-items:center;gap:10px;background:#00C2FF;color:#080C14;font-size:0.95rem;font-weight:700;padding:14px 28px;border-radius:9999px;border:none;cursor:pointer;font-family:inherit;">
        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
        Join the Waitlist
      </button>
    </div>
  </section>

  <!-- HOW PRICING WORKS -->
  <section style="padding:80px 24px;max-width:1280px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:56px;">
      <h2 style="font-size:clamp(1.5rem,3vw,2.25rem);font-weight:800;color:#ffffff;margin-bottom:12px;">How our pricing works</h2>
      <p style="color:#8B96A8;max-width:560px;margin:0 auto;line-height:1.7;">Tow It uses a simple, formula-based pricing model. Your quote is calculated automatically by our AI based on four factors.</p>
    </div>
    <div style="margin-bottom:40px;border-radius:16px;overflow:hidden;">
      <img src="/images/pricing-clear-quote.jpg" alt="Customer receiving instant clear vehicle transport price on WhatsApp" style="width:100%;max-height:300px;object-fit:cover;border-radius:16px;display:block;" />
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:24px;">
      <div style="background:#141C2E;border:1px solid #1A2540;border-radius:16px;padding:28px;">
        <div style="color:#00C2FF;font-size:2rem;margin-bottom:12px;">📍</div>
        <h3 style="color:#ffffff;font-weight:700;margin-bottom:10px;">Distance</h3>
        <p style="color:#8B96A8;font-size:0.9rem;line-height:1.7;">The primary driver of cost is the actual road distance between collection and delivery point. We use live routing data — not straight-line — to calculate the true journey distance. Longer journeys cost more, but at a decreasing rate per mile (bulk distance is cheaper per mile).</p>
      </div>
      <div style="background:#141C2E;border:1px solid #1A2540;border-radius:16px;padding:28px;">
        <div style="color:#00E88F;font-size:2rem;margin-bottom:12px;">🚗</div>
        <h3 style="color:#ffffff;font-weight:700;margin-bottom:10px;">Vehicle Type</h3>
        <p style="color:#8B96A8;font-size:0.9rem;line-height:1.7;">Standard cars are our base rate. Large SUVs, vans, prestige vehicles, and non-runners carry different rates reflecting the equipment and care required. Motorcycles have their own pricing. We'll ask about the vehicle in your WhatsApp message.</p>
      </div>
      <div style="background:#141C2E;border:1px solid #1A2540;border-radius:16px;padding:28px;">
        <div style="color:#FF6B2B;font-size:2rem;margin-bottom:12px;">📅</div>
        <h3 style="color:#ffffff;font-weight:700;margin-bottom:10px;">Timing &amp; Urgency</h3>
        <p style="color:#8B96A8;font-size:0.9rem;line-height:1.7;">Same-day and next-day bookings may carry a small premium to account for driver availability. Standard bookings (3+ days notice) are at our base rate. We'll always show you the price before you commit — if urgency adds cost, you'll see it clearly.</p>
      </div>
      <div style="background:#141C2E;border:1px solid #1A2540;border-radius:16px;padding:28px;">
        <div style="color:#00C2FF;font-size:2rem;margin-bottom:12px;">🏆</div>
        <h3 style="color:#ffffff;font-weight:700;margin-bottom:10px;">Account Type</h3>
        <p style="color:#8B96A8;font-size:0.9rem;line-height:1.7;">Dealer accounts and regular customers unlock volume-based pricing. The more you move, the lower your per-vehicle cost. One-off public bookings are at standard rates. All rates include VAT at the applicable rate.</p>
      </div>
    </div>
  </section>

  <!-- DEALER RATE STRUCTURE -->
  <section style="padding:80px 24px;max-width:1280px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:56px;">
      <p style="color:#00C2FF;font-size:0.875rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:10px;">Dealer Pricing</p>
      <h2 style="font-size:clamp(1.5rem,3vw,2.25rem);font-weight:800;color:#ffffff;margin-bottom:12px;">Rate structure by distance</h2>
      <p style="color:#8B96A8;max-width:540px;margin:0 auto;line-height:1.7;">All dealer jobs are priced by distance band. All prices are exclusive of VAT. The quote you receive is always fixed — no fuel surcharges, no surprises.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-bottom:32px;">

      <!-- Short Journey -->
      <div style="background:#141C2E;border:1px solid #1A2540;border-radius:16px;padding:36px;text-align:center;">
        <div style="color:#8B96A8;font-size:0.8rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px;">Short Journey</div>
        <div style="color:#ffffff;font-size:2.75rem;font-weight:900;margin-bottom:4px;">£120</div>
        <div style="color:#8B96A8;font-size:0.9rem;margin-bottom:6px;">flat rate + VAT</div>
        <div style="background:#0E1421;border-radius:8px;padding:10px 16px;margin:20px 0;display:inline-block;">
          <span style="color:#00C2FF;font-weight:700;">Up to 50 miles</span>
        </div>
        <p style="color:#8B96A8;font-size:0.875rem;line-height:1.7;">One flat price regardless of exact distance. Ideal for same-city transfers, local auction runs, and part-exchange collections.</p>
      </div>

      <!-- Standard -->
      <div style="background:#141C2E;border:2px solid #00C2FF;border-radius:16px;padding:36px;text-align:center;position:relative;">
        <div style="position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:#00C2FF;color:#080C14;font-size:0.75rem;font-weight:700;padding:4px 16px;border-radius:9999px;white-space:nowrap;">MOST COMMON</div>
        <div style="color:#00C2FF;font-size:0.8rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px;">Standard</div>
        <div style="color:#ffffff;font-size:2.75rem;font-weight:900;margin-bottom:4px;">£120<span style="font-size:1.25rem;font-weight:600;color:#8B96A8;"> base</span></div>
        <div style="color:#8B96A8;font-size:0.9rem;margin-bottom:6px;">+ £2.35/mi over 50 + VAT</div>
        <div style="background:#0E1421;border-radius:8px;padding:10px 16px;margin:20px 0;display:inline-block;">
          <span style="color:#00C2FF;font-weight:700;">51 – 100 miles</span>
        </div>
        <p style="color:#8B96A8;font-size:0.875rem;line-height:1.7;">Example: 76-mile job = £120 + (26 &times; £2.35) = <strong style="color:#ffffff;">£181.10 + VAT</strong></p>
      </div>

      <!-- Long Distance -->
      <div style="background:#141C2E;border:1px solid #1A2540;border-radius:16px;padding:36px;text-align:center;">
        <div style="color:#00E88F;font-size:0.8rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px;">Long Distance</div>
        <div style="color:#ffffff;font-size:2.75rem;font-weight:900;margin-bottom:4px;">£2.05</div>
        <div style="color:#8B96A8;font-size:0.9rem;margin-bottom:6px;">per mile + VAT</div>
        <div style="background:#0E1421;border-radius:8px;padding:10px 16px;margin:20px 0;display:inline-block;">
          <span style="color:#00E88F;font-weight:700;">100+ miles</span>
        </div>
        <p style="color:#8B96A8;font-size:0.875rem;line-height:1.7;">No base charge — just a simple per-mile rate. Example: 250-mile run = <strong style="color:#ffffff;">£512.50 + VAT</strong></p>
      </div>

    </div>
    <p style="text-align:center;color:#4A5568;font-size:0.8rem;">All prices are for standard passenger cars. Large SUVs, prestige vehicles, and non-runners may carry an additional charge. Custom rates available for national dealer groups — speak to your account manager.</p>
  </section>

  <!-- NO HIDDEN FEES -->
  <section style="padding:80px 24px;max-width:1280px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:56px;">
      <h2 style="font-size:clamp(1.5rem,3vw,2.25rem);font-weight:800;color:#ffffff;margin-bottom:12px;">What's included — and what isn't</h2>
      <p style="color:#8B96A8;max-width:560px;margin:0 auto;line-height:1.7;">We're deliberately transparent about what our pricing includes. No small-print surprises.</p>
    </div>
    <div style="margin-bottom:40px;border-radius:16px;overflow:hidden;">
      <img src="/images/pricing-no-fees.jpg" alt="Transparent pricing with no hidden fees" style="width:100%;max-height:280px;object-fit:cover;border-radius:16px;display:block;" />
    </div>
    <div class="pricing-included-grid">
      <div style="background:#141C2E;border:1px solid #00E88F;border-radius:16px;padding:32px;">
        <h3 style="color:#00E88F;font-weight:700;margin-bottom:20px;display:flex;align-items:center;gap:8px;">
          <span>✓</span> Always included
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px;">
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#00E88F;flex-shrink:0;">✓</span>Collection from any UK postcode</li>
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#00E88F;flex-shrink:0;">✓</span>Delivery to any UK postcode</li>
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#00E88F;flex-shrink:0;">✓</span>Goods-in-transit and motor trade insurance</li>
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#00E88F;flex-shrink:0;">✓</span>Pre-collection vehicle condition check</li>
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#00E88F;flex-shrink:0;">✓</span>WhatsApp status updates throughout</li>
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#00E88F;flex-shrink:0;">✓</span>Delivery confirmation and report</li>
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#00E88F;flex-shrink:0;">✓</span>24/7 AI support for your booking</li>
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#00E88F;flex-shrink:0;">✓</span>VAT (where applicable)</li>
        </ul>
      </div>
      <div style="background:#141C2E;border:1px solid #1A2540;border-radius:16px;padding:32px;">
        <h3 style="color:#FF6B2B;font-weight:700;margin-bottom:20px;display:flex;align-items:center;gap:8px;">
          <span>✕</span> Never charged
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px;">
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#FF6B2B;flex-shrink:0;">✕</span>Buyer protection fees (charged by competitors)</li>
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#FF6B2B;flex-shrink:0;">✕</span>Platform or booking fees</li>
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#FF6B2B;flex-shrink:0;">✕</span>Account registration or monthly fees</li>
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#FF6B2B;flex-shrink:0;">✕</span>Cancellation fees (24hrs+ notice)</li>
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#FF6B2B;flex-shrink:0;">✕</span>Fuel surcharges (included in base price)</li>
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#FF6B2B;flex-shrink:0;">✕</span>Congestion or ULEZ charges (included)</li>
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#FF6B2B;flex-shrink:0;">✕</span>Weekend or evening surcharges</li>
          <li style="color:#8B96A8;font-size:0.9rem;display:flex;align-items:start;gap:10px;line-height:1.5;"><span style="color:#FF6B2B;flex-shrink:0;">✕</span>Anything not in your original quote</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section style="padding:0 24px 80px;background:#0E1421;border-top:1px solid #1A2540;border-bottom:1px solid #1A2540;padding-top:80px;padding-bottom:80px;">
    <div style="max-width:1000px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:48px;">
        <h2 style="font-size:clamp(1.5rem,3vw,2.25rem);font-weight:800;color:#ffffff;margin-bottom:12px;">How we compare to the alternatives</h2>
        <p style="color:#8B96A8;font-size:0.95rem;max-width:540px;margin:0 auto;line-height:1.7;">Competing platforms all have costs and friction that aren't obvious from their marketing. Here's a real comparison.</p>
      </div>
      <div style="background:#141C2E;border:1px solid #1A2540;border-radius:16px;overflow:hidden;">
        <div class="pricing-table-wrap">
          <div class="pricing-table-inner">
            <div style="display:grid;grid-template-columns:2fr 1fr 1fr 1fr;background:#0E1421;padding:16px 24px;border-bottom:1px solid #1A2540;">
              <div style="color:#8B96A8;font-size:0.8rem;font-weight:600;text-transform:uppercase;"></div>
              <div style="color:#00C2FF;font-size:0.875rem;font-weight:700;text-align:center;">Tow It</div>
              <div style="color:#8B96A8;font-size:0.8rem;font-weight:600;text-align:center;">Competitor A</div>
              <div style="color:#8B96A8;font-size:0.8rem;font-weight:600;text-align:center;">Competitor B</div>
            </div>
            <div style="display:grid;grid-template-columns:2fr 1fr 1fr 1fr;padding:14px 24px;border-bottom:1px solid #1A2540;align-items:center;">
              <div style="color:#8B96A8;font-size:0.875rem;">Instant pricing</div>
              <div style="text-align:center;color:#00E88F;font-weight:600;">✓ Yes</div>
              <div style="text-align:center;color:#4A5568;white-space:nowrap;">Wait for bids</div>
              <div style="text-align:center;color:#4A5568;white-space:nowrap;">Estimate only</div>
            </div>
            <div style="display:grid;grid-template-columns:2fr 1fr 1fr 1fr;padding:14px 24px;border-bottom:1px solid #1A2540;align-items:center;background:rgba(255,255,255,0.02);">
              <div style="color:#8B96A8;font-size:0.875rem;">Platform/booking fees</div>
              <div style="text-align:center;color:#00E88F;font-weight:600;">£0</div>
              <div style="text-align:center;color:#FF6B2B;">5–15%</div>
              <div style="text-align:center;color:#FF6B2B;">Yes</div>
            </div>
            <div style="display:grid;grid-template-columns:2fr 1fr 1fr 1fr;padding:14px 24px;border-bottom:1px solid #1A2540;align-items:center;">
              <div style="color:#8B96A8;font-size:0.875rem;">Drivers pre-vetted</div>
              <div style="text-align:center;color:#00E88F;font-weight:600;">✓ Always</div>
              <div style="text-align:center;color:#FF6B2B;white-space:nowrap;">No — you choose</div>
              <div style="text-align:center;color:#4A5568;">Partially</div>
            </div>
            <div style="display:grid;grid-template-columns:2fr 1fr 1fr 1fr;padding:14px 24px;border-bottom:1px solid #1A2540;align-items:center;background:rgba(255,255,255,0.02);">
              <div style="color:#8B96A8;font-size:0.875rem;">Booking interface</div>
              <div style="text-align:center;color:#00E88F;font-weight:600;">WhatsApp</div>
              <div style="text-align:center;color:#4A5568;white-space:nowrap;">Website form</div>
              <div style="text-align:center;color:#4A5568;white-space:nowrap;">App / website</div>
            </div>
            <div style="display:grid;grid-template-columns:2fr 1fr 1fr 1fr;padding:14px 24px;border-bottom:1px solid #1A2540;align-items:center;">
              <div style="color:#8B96A8;font-size:0.875rem;">Time to confirmed quote</div>
              <div style="text-align:center;color:#00E88F;font-weight:600;white-space:nowrap;">&lt; 2 mins</div>
              <div style="text-align:center;color:#4A5568;white-space:nowrap;">Hours–days</div>
              <div style="text-align:center;color:#4A5568;white-space:nowrap;">30–60 mins</div>
            </div>
            <div style="display:grid;grid-template-columns:2fr 1fr 1fr 1fr;padding:14px 24px;border-bottom:1px solid #1A2540;align-items:center;background:rgba(255,255,255,0.02);">
              <div style="color:#8B96A8;font-size:0.875rem;">Available 24/7</div>
              <div style="text-align:center;color:#00E88F;font-weight:600;">✓ Yes</div>
              <div style="text-align:center;color:#4A5568;white-space:nowrap;">Site only</div>
              <div style="text-align:center;color:#4A5568;white-space:nowrap;">Limited hours</div>
            </div>
            <div style="display:grid;grid-template-columns:2fr 1fr 1fr 1fr;padding:14px 24px;align-items:center;">
              <div style="color:#8B96A8;font-size:0.875rem;">Dealer accounts</div>
              <div style="text-align:center;color:#00E88F;font-weight:600;white-space:nowrap;">✓ Dedicated</div>
              <div style="text-align:center;color:#4A5568;">No</div>
              <div style="text-align:center;color:#4A5568;">Limited</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding:80px 24px;text-align:center;">
    <div style="max-width:600px;margin:0 auto;">
      <h2 style="font-size:clamp(1.5rem,3vw,2.25rem);font-weight:800;color:#ffffff;margin-bottom:16px;">Get your exact price now</h2>
      <p style="color:#8B96A8;margin-bottom:32px;line-height:1.7;">The quickest way to get your exact price is to message us on WhatsApp with your collection point, delivery point, and vehicle details. You'll have a quote in under 2 minutes.</p>
      <button onclick="openWaitlistModal()" style="display:inline-flex;align-items:center;gap:10px;background:#00C2FF;color:#080C14;font-size:1rem;font-weight:700;padding:14px 32px;border-radius:9999px;border:none;cursor:pointer;font-family:inherit;margin-bottom:16px;">
        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
        Join the Waitlist
      </button>
      <p style="color:#4A5568;font-size:0.8rem;">No obligation · No account needed · Reply in under 2 minutes</p>
    </div>
  </section>

</Layout>
