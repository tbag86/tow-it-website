            <li><a href="/for-dealers" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Dealer Partnerships</a></li>
            <li><a href="/auction-collections" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Auction Collections</a></li>
            <li><a href="/international-car-transport" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">International Car Transport</a></li>
          </ul>
        </div>
        <div>
          <h3 style="color:#ffffff;font-weight:600;font-size:0.875rem;margin-bottom:16px;">Partners</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
            <li><a href="/for-transport-companies" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Transport Companies</a></li>
            <li><a href="/for-dealers" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Car Dealers</a></li>
            <li><a href="/for-transport-companies#register" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Driver Registration</a></li>
          </ul>
        </div>
        <div>
          <h3 style="color:#ffffff;font-weight:600;font-size:0.875rem;margin-bottom:16px;">Company</h3>
