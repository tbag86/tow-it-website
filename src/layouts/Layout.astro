---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}
const { title, description, canonical, ogImage = '/og-default.jpg' } = Astro.props;
const canonicalURL = canonical || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en-GB" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Tow It — AI Vehicle Transport UK</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content="index, follow" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} | Tow It`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Tow It" />
  <meta property="og:locale" content="en_GB" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | Tow It`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Tow It",
    "url": "https://towit.ai",
    "description": "AI-powered vehicle transport broker operating across the UK via WhatsApp",
    "email": "hello@towit.ai",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "GB"
    },
    "sameAs": [
      "https://wa.me/447700000000"
    ]
  }
  </script>
</head>
<body style="background-color:#080C14;color:#ffffff;font-family:'Inter',system-ui,sans-serif;">
  <nav style="position:fixed;top:0;left:0;right:0;z-index:50;background-color:rgba(8,12,20,0.95);backdrop-filter:blur(12px);border-bottom:1px solid #1A2540;">
    <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;">
      <div style="display:flex;align-items:center;justify-content:space-between;height:64px;">
        <a href="/" style="display:flex;align-items:center;text-decoration:none;">
          <img src="/logo.png" alt="Tow It Ai" style="height:48px;width:auto;" />
        </a>
        <div class="desktop-nav" style="display:flex;align-items:center;gap:24px;">
          <a href="/how-it-works" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;transition:color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">How It Works</a>
          <a href="/for-dealers" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">For Dealers</a>
          <a href="/auction-collections" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Auction Collections</a>
          <a href="/for-transport-companies" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Transport Companies</a>
          <a href="/pricing" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Pricing</a>
          <a href="/about" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">About</a>
          <a href="/contact" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Contact</a>
        </div>
        <div style="display:flex;align-items:center;gap:10px;">
          <!-- JOIN WAITLIST — desktop -->
          <button onclick="openWaitlistModal()" class="waitlist-nav-btn" style="display:inline-flex;align-items:center;gap:6px;background:transparent;border:1.5px solid #00C2FF;color:#00C2FF;font-size:0.8rem;font-weight:600;padding:7px 16px;border-radius:9999px;cursor:pointer;font-family:inherit;transition:all 0.2s;" onmouseover="this.style.background='rgba(0,194,255,0.1)'" onmouseout="this.style.background='transparent'">
            <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
            Join Waitlist
          </button>
          <a href="https://wa.me/447700000000?text=Hi%20Tow%20It%2C%20I%20need%20a%20vehicle%20transport%20quote" target="_blank" rel="noopener" class="wa-nav-btn" style="display:inline-flex;align-items:center;gap:8px;background:#25D366;color:#ffffff;font-size:0.875rem;font-weight:600;padding:8px 18px;border-radius:9999px;text-decoration:none;">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
