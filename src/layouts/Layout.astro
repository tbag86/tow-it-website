  <script>
    // =============================================
    // VINI CHAT WIDGET
    // =============================================
    var chatOpen = false;
    var chatHistory = []; // [{role: 'user'|'assistant', content: '...'}]
    var chatSending = false;

    function toggleChat() {
      chatOpen = !chatOpen;
      const panel = document.getElementById('chat-panel');
      const iconOpen = document.getElementById('chat-bubble-icon-open');
      const iconClose = document.getElementById('chat-bubble-icon-close');
      const notif = document.getElementById('chat-notif-dot');

      if (chatOpen) {
        panel.style.display = 'flex';
        panel.style.flexDirection = 'column';
        iconOpen.style.display = 'none';
        iconClose.style.display = 'block';
        notif.style.display = 'none';
        // Focus input
        setTimeout(() => {
          const input = document.getElementById('chat-input');
          if (input) input.focus();
          scrollChatToBottom();
        }, 100);
      } else {
        panel.style.display = 'none';
        iconOpen.style.display = 'block';
        iconClose.style.display = 'none';
      }
    }

    function scrollChatToBottom() {
      const msgs = document.getElementById('chat-messages');
      if (msgs) msgs.scrollTop = msgs.scrollHeight;
    }

    function autoResizeChatInput(el) {
      el.style.height = 'auto';
      el.style.height = Math.min(el.scrollHeight, 100) + 'px';
    }

    function handleChatKeydown(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendChatMessage();
      }
    }

    function appendUserMessage(text) {
      const msgs = document.getElementById('chat-messages');
      const div = document.createElement('div');
      div.style.cssText = 'display:flex;justify-content:flex-end;';
      div.innerHTML = '<div style="max-width:82%;background:#00C2FF;border-radius:16px 16px 4px 16px;padding:10px 14px;"><p style="color:#080C14;font-size:0.875rem;line-height:1.6;margin:0;word-break:break-word;">' + escapeHtml(text) + '</p></div>';
      msgs.appendChild(div);
      scrollChatToBottom();
    }

    function appendViniMessage(text) {
      const msgs = document.getElementById('chat-messages');

      // Split on [SHOW_WAITLIST_BUTTON] marker
      const parts = text.split('[SHOW_WAITLIST_BUTTON]');
      const messageText = parts[0].trim();
      const showButton = parts.length > 1;

      const div = document.createElement('div');
      div.className = 'chat-msg-vini';
      div.style.cssText = 'display:flex;gap:10px;align-items:flex-start;';

      let btnHtml = '';
      if (showButton) {
        btnHtml = '<div style="margin-top:10px;"><button onclick="openWaitlistModal();toggleChat();" style="display:inline-flex;align-items:center;gap:7px;background:#00C2FF;border:none;color:#080C14;font-size:0.82rem;font-weight:700;padding:9px 18px;border-radius:9999px;cursor:pointer;font-family:inherit;">'+
          '<svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>'+
          'Join the Waitlist</button></div>';
      }

      div.innerHTML =
        '<div style="width:30px;height:30px;background:linear-gradient(135deg,#00C2FF,#0099CC);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;color:#fff;flex-shrink:0;margin-top:2px;">V</div>'+
        '<div style="max-width:82%;background:#141C2E;border:1px solid #1A2540;border-radius:16px 16px 16px 4px;padding:12px 14px;">'+
          '<p style="color:#ffffff;font-size:0.875rem;line-height:1.6;margin:0;white-space:pre-wrap;word-break:break-word;">' + escapeHtml(messageText) + '</p>'+
          btnHtml +
        '</div>';

      msgs.appendChild(div);
      scrollChatToBottom();
    }

    function showTyping(show) {
      const t = document.getElementById('chat-typing');
      if (t) t.style.display = show ? 'block' : 'none';
      if (show) scrollChatToBottom();
    }

    function escapeHtml(str) {
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    async function sendChatMessage() {
      if (chatSending) return;
      const input = document.getElementById('chat-input');
      const text = input.value.trim();
      if (!text) return;

      // Clear input
      input.value = '';
      input.style.height = 'auto';

      // Add to UI and history
      appendUserMessage(text);
      chatHistory.push({ role: 'user', content: text });

      // Disable send, show typing
      chatSending = true;
      document.getElementById('chat-send-btn').style.opacity = '0.4';
      showTyping(true);

      try {
        const response = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: chatHistory }),
        });

        const result = await response.json();
        showTyping(false);

        if (result.success && result.message) {
          appendViniMessage(result.message);
          chatHistory.push({ role: 'assistant', content: result.message });
        } else {
          appendViniMessage("Sorry, I had a little hiccup there. Could you try again? 😅");
        }
      } catch (err) {
        showTyping(false);
        appendViniMessage("Looks like there's a connection issue. Please try again in a moment!");
      }

      chatSending = false;
      document.getElementById('chat-send-btn').style.opacity = '1';
      input.focus();
    }
  </script>

  <script>
    // =============================================
    // HORIZONTAL SCROLL — mouse drag support
    // =============================================
    document.querySelectorAll('.hscroll-track').forEach(function(track) {
      var isDown = false;
      var startX;
      var scrollLeft;

      track.addEventListener('mousedown', function(e) {
        isDown = true;
        track.classList.add('active');
        startX = e.pageX - track.offsetLeft;
        scrollLeft = track.scrollLeft;
        e.preventDefault();
      });

      track.addEventListener('mouseleave', function() {
        isDown = false;
        track.classList.remove('active');
      });

      track.addEventListener('mouseup', function() {
        isDown = false;
        track.classList.remove('active');
      });

      track.addEventListener('mousemove', function(e) {
        if (!isDown) return;
        e.preventDefault();
        var x = e.pageX - track.offsetLeft;
        var walk = (x - startX) * 1.5;
        track.scrollLeft = scrollLeft - walk;
      });
    });
  </script>
</body>
</html>
