      <!-- Modal Header -->
      <div style="background:linear-gradient(135deg,#0E1421,#141C2E);padding:28px 32px 24px;border-bottom:1px solid #1A2540;position:relative;">
        <button onclick="closeWaitlistModal()" style="position:absolute;top:20px;right:20px;background:#1A2540;border:none;color:#8B96A8;width:32px;height:32px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;line-height:1;" aria-label="Close">&times;</button>
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
          <div style="width:36px;height:36px;background:rgba(0,194,255,0.12);border-radius:10px;display:flex;align-items:center;justify-content:center;">
            <svg width="18" height="18" fill="none" stroke="#00C2FF" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          </div>
          <div>
            <h2 style="color:#ffffff;font-size:1.25rem;font-weight:700;margin:0;">Join the Waitlist</h2>
            <p style="color:#8B96A8;font-size:0.8rem;margin:2px 0 0;">Be first to access Towit.ai when we launch</p>
          </div>
        </div>
      </div>

      <!-- Form State -->
      <div id="waitlist-form-state" style="padding:28px 32px;">
        <form id="waitlist-form" novalidate>

          <!-- Name + Email row -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;" class="waitlist-2col">
            <div>
              <label style="display:block;color:#8B96A8;font-size:0.8rem;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em;">Full Name <span style="color:#00C2FF;">*</span></label>
              <input type="text" name="name" id="wl-name" required placeholder="e.g. James Smith" style="width:100%;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;color:#ffffff;font-size:0.9rem;padding:10px 14px;font-family:inherit;outline:none;box-sizing:border-box;" onfocus="this.style.borderColor='#00C2FF'" onblur="this.style.borderColor='#1A2540'" />
            </div>
            <div>
              <label style="display:block;color:#8B96A8;font-size:0.8rem;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em;">Email Address <span style="color:#00C2FF;">*</span></label>
              <input type="email" name="email" id="wl-email" required placeholder="you@example.com" style="width:100%;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;color:#ffffff;font-size:0.9rem;padding:10px 14px;font-family:inherit;outline:none;box-sizing:border-box;" onfocus="this.style.borderColor='#00C2FF'" onblur="this.style.borderColor='#1A2540'" />
            </div>
          </div>

          <!-- Phone -->
          <div style="margin-bottom:14px;">
            <label style="display:block;color:#8B96A8;font-size:0.8rem;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em;">WhatsApp / Mobile Number <span style="color:#4A5568;">(optional)</span></label>
            <input type="tel" name="phone" id="wl-phone" placeholder="+44 7700 000000" style="width:100%;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;color:#ffffff;font-size:0.9rem;padding:10px 14px;font-family:inherit;outline:none;box-sizing:border-box;" onfocus="this.style.borderColor='#00C2FF'" onblur="this.style.borderColor='#1A2540'" />
          </div>

          <!-- Role selector -->
          <div style="margin-bottom:14px;">
            <label style="display:block;color:#8B96A8;font-size:0.8rem;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em;">I am a... <span style="color:#00C2FF;">*</span></label>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
              <label id="role-customer-label" style="display:flex;align-items:center;gap:10px;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;padding:12px 14px;cursor:pointer;transition:border-color 0.2s;">
                <input type="radio" name="role" value="customer" id="wl-role-customer" style="display:none;" onchange="handleRoleChange(this.value)" />
                <div id="radio-customer" style="width:16px;height:16px;border-radius:50%;border:2px solid #4A5568;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all 0.2s;"></div>
                <div>
                  <div style="color:#ffffff;font-size:0.85rem;font-weight:600;">Customer</div>
                  <div style="color:#8B96A8;font-size:0.75rem;margin-top:1px;">I need a vehicle transported</div>
                </div>
              </label>
              <label id="role-driver-label" style="display:flex;align-items:center;gap:10px;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;padding:12px 14px;cursor:pointer;transition:border-color 0.2s;">
                <input type="radio" name="role" value="driver" id="wl-role-driver" style="display:none;" onchange="handleRoleChange(this.value)" />
                <div id="radio-driver" style="width:16px;height:16px;border-radius:50%;border:2px solid #4A5568;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all 0.2s;"></div>
                <div>
                  <div style="color:#ffffff;font-size:0.85rem;font-weight:600;">Driver / Company</div>
                  <div style="color:#8B96A8;font-size:0.75rem;margin-top:1px;">I want to deliver vehicles</div>
                </div>
              </label>
            </div>
          </div>

          <!-- CUSTOMER FIELDS -->
          <div id="customer-fields" style="display:none;margin-bottom:14px;">
            <label style="display:block;color:#8B96A8;font-size:0.8rem;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em;">What service are you interested in?</label>
            <select name="service_type" id="wl-service-type" style="width:100%;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;color:#ffffff;font-size:0.9rem;padding:10px 14px;font-family:inherit;outline:none;appearance:none;box-sizing:border-box;" onfocus="this.style.borderColor='#00C2FF'" onblur="this.style.borderColor='#1A2540'">
              <option value="">— Please select —</option>
              <option value="Private / personal car transport">Private / personal car transport</option>
              <option value="Dealer / trade transport">Dealer / trade transport</option>
              <option value="Auction collection">Auction collection</option>
              <option value="Fleet / multiple vehicles">Fleet / multiple vehicles</option>
              <option value="International transport">International transport</option>
              <option value="Not sure yet">Not sure yet</option>
            </select>
          </div>

          <!-- DRIVER FIELDS -->
          <div id="driver-fields" style="display:none;">
            <div style="margin-bottom:14px;">
              <label style="display:block;color:#8B96A8;font-size:0.8rem;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em;">Vehicle / Equipment Type</label>
              <select name="vehicle_type" id="wl-vehicle-type" style="width:100%;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;color:#ffffff;font-size:0.9rem;padding:10px 14px;font-family:inherit;outline:none;appearance:none;box-sizing:border-box;" onfocus="this.style.borderColor='#00C2FF'" onblur="this.style.borderColor='#1A2540'">
                <option value="">— Please select —</option>
                <option value="Single car transporter">Single car transporter</option>
                <option value="Multi-car transporter (2–4 cars)">Multi-car transporter (2–4 cars)</option>
                <option value="Large car transporter (5+ cars)">Large car transporter (5+ cars)</option>
                <option value="Recovery / breakdown truck">Recovery / breakdown truck</option>
                <option value="Enclosed transporter">Enclosed transporter</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div style="margin-bottom:14px;">
              <label style="display:block;color:#8B96A8;font-size:0.8rem;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em;">Your Base Location</label>
              <input type="text" name="base_location" id="wl-base-location" placeholder="e.g. Birmingham, West Midlands" style="width:100%;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;color:#ffffff;font-size:0.9rem;padding:10px 14px;font-family:inherit;outline:none;box-sizing:border-box;" onfocus="this.style.borderColor='#00C2FF'" onblur="this.style.borderColor='#1A2540'" />
            </div>
          </div>

          <!-- How did you hear about us -->
          <div style="margin-bottom:14px;">
            <label style="display:block;color:#8B96A8;font-size:0.8rem;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em;">How did you hear about us? <span style="color:#4A5568;">(optional)</span></label>
            <select name="heard_from" id="wl-heard-from" style="width:100%;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;color:#ffffff;font-size:0.9rem;padding:10px 14px;font-family:inherit;outline:none;appearance:none;box-sizing:border-box;" onfocus="this.style.borderColor='#00C2FF'" onblur="this.style.borderColor='#1A2540'">
              <option value="">— Select one —</option>
              <option value="Google / Search">Google / Search</option>
              <option value="Instagram">Instagram</option>
              <option value="TikTok">TikTok</option>
              <option value="Facebook">Facebook</option>
              <option value="Word of mouth / referral">Word of mouth / referral</option>
              <option value="Industry contact">Industry contact</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <!-- Notes -->
          <div style="margin-bottom:22px;">
            <label style="display:block;color:#8B96A8;font-size:0.8rem;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em;">Anything else you'd like us to know? <span style="color:#4A5568;">(optional)</span></label>
            <textarea name="notes" id="wl-notes" rows="3" placeholder="Any specific requirements, questions or details..." style="width:100%;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;color:#ffffff;font-size:0.9rem;padding:10px 14px;font-family:inherit;outline:none;resize:vertical;box-sizing:border-box;" onfocus="this.style.borderColor='#00C2FF'" onblur="this.style.borderColor='#1A2540'"></textarea>
          </div>

          <!-- Error message -->
          <div id="wl-error" style="display:none;background:rgba(255,107,43,0.1);border:1px solid rgba(255,107,43,0.3);border-radius:10px;padding:12px 16px;margin-bottom:16px;color:#FF6B2B;font-size:0.85rem;"></div>

          <!-- Submit -->
          <button type="submit" id="wl-submit-btn" style="width:100%;background:#00C2FF;color:#080C14;font-size:1rem;font-weight:700;padding:14px 24px;border-radius:10px;border:none;cursor:pointer;font-family:inherit;transition:opacity 0.2s;display:flex;align-items:center;justify-content:center;gap:8px;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
            <svg id="wl-submit-icon" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
            <span id="wl-submit-text">Join the Waitlist</span>
          </button>

          <p style="color:#4A5568;font-size:0.75rem;text-align:center;margin-top:12px;">No spam. Unsubscribe any time. We'll only contact you about Towit.ai.</p>
        </form>
      </div>

      <!-- Success State (hidden by default) -->
      <div id="waitlist-success-state" style="display:none;padding:48px 32px;text-align:center;">
        <div style="width:64px;height:64px;background:rgba(0,232,143,0.12);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
          <svg width="32" height="32" fill="none" stroke="#00E88F" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
        </div>
        <h3 style="color:#ffffff;font-size:1.4rem;font-weight:700;margin-bottom:10px;">You're on the list! 🚀</h3>
        <p style="color:#8B96A8;font-size:0.95rem;line-height:1.7;max-width:380px;margin:0 auto 24px;">Thanks for joining — we'll be in touch as soon as we launch. Keep an eye on your inbox!</p>
        <button onclick="closeWaitlistModal()" style="background:#1A2540;border:none;color:#8B96A8;font-size:0.875rem;font-weight:600;padding:10px 24px;border-radius:9999px;cursor:pointer;font-family:inherit;">Close</button>
      </div>

    </div>
  </div>
  <!-- END WAITLIST MODAL -->

  <style>
    @media (max-width: 768px) {
      .desktop-nav { display: none !important; }
      .wa-nav-btn { display: none !important; }
      .waitlist-nav-btn { display: none !important; }
      #mobile-menu-btn { display: block !important; }
      .waitlist-2col { grid-template-columns: 1fr !important; }
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
    select option { background: #141C2E; color: #ffffff; }
    #waitlist-overlay { display: flex; align-items: flex-start; justify-content: center; }
    #waitlist-overlay[style*="display:none"] { display: none !important; }
  </style>

  <script>
    // Mobile menu toggle
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', () => {
        menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
      });
    }

    // =============================================
    // WAITLIST MODAL
    // =============================================
    function openWaitlistModal(presetRole) {
      const overlay = document.getElementById('waitlist-overlay');
      overlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      // Pre-select role if passed
      if (presetRole === 'customer' || presetRole === 'driver') {
        const radio = document.getElementById('wl-role-' + presetRole);
        if (radio) {
          radio.checked = true;
          handleRoleChange(presetRole);
        }
      }
    }

    function closeWaitlistModal() {
      const overlay = document.getElementById('waitlist-overlay');
      overlay.style.display = 'none';
      document.body.style.overflow = '';
      // Reset form after brief delay
      setTimeout(() => {
        resetWaitlistForm();
      }, 300);
    }

    function handleOverlayClick(e) {
      if (e.target === document.getElementById('waitlist-overlay')) {
        closeWaitlistModal();
      }
    }

    // ESC key closes modal
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeWaitlistModal();
    });

    function handleRoleChange(role) {
      const customerFields = document.getElementById('customer-fields');
      const driverFields = document.getElementById('driver-fields');
      const customerLabel = document.getElementById('role-customer-label');
      const driverLabel = document.getElementById('role-driver-label');
      const radioCustomer = document.getElementById('radio-customer');
      const radioDriver = document.getElementById('radio-driver');

      if (role === 'customer') {
        customerFields.style.display = 'block';
        driverFields.style.display = 'none';
        customerLabel.style.borderColor = '#00C2FF';
        driverLabel.style.borderColor = '#1A2540';
        radioCustomer.style.borderColor = '#00C2FF';
        radioCustomer.innerHTML = '<div style="width:8px;height:8px;background:#00C2FF;border-radius:50%;"></div>';
        radioDriver.style.borderColor = '#4A5568';
        radioDriver.innerHTML = '';
      } else if (role === 'driver') {
        customerFields.style.display = 'none';
        driverFields.style.display = 'block';
        driverLabel.style.borderColor = '#00E88F';
        customerLabel.style.borderColor = '#1A2540';
        radioDriver.style.borderColor = '#00E88F';
        radioDriver.innerHTML = '<div style="width:8px;height:8px;background:#00E88F;border-radius:50%;"></div>';
        radioCustomer.style.borderColor = '#4A5568';
        radioCustomer.innerHTML = '';
      }
    }

    function resetWaitlistForm() {
      const form = document.getElementById('waitlist-form');
      if (form) form.reset();
      document.getElementById('customer-fields').style.display = 'none';
      document.getElementById('driver-fields').style.display = 'none';
      document.getElementById('role-customer-label').style.borderColor = '#1A2540';
      document.getElementById('role-driver-label').style.borderColor = '#1A2540';
      document.getElementById('radio-customer').style.borderColor = '#4A5568';
      document.getElementById('radio-customer').innerHTML = '';
      document.getElementById('radio-driver').style.borderColor = '#4A5568';
      document.getElementById('radio-driver').innerHTML = '';
      document.getElementById('wl-error').style.display = 'none';
      document.getElementById('waitlist-form-state').style.display = 'block';
      document.getElementById('waitlist-success-state').style.display = 'none';
      const submitBtn = document.getElementById('wl-submit-btn');
      submitBtn.disabled = false;
      submitBtn.style.opacity = '1';
      document.getElementById('wl-submit-text').textContent = 'Join the Waitlist';
      document.getElementById('wl-submit-icon').style.display = 'inline';
    }

    // Form submission
    document.getElementById('waitlist-form').addEventListener('submit', async function(e) {
      e.preventDefault();

      const errorEl = document.getElementById('wl-error');
      errorEl.style.display = 'none';

      const name = document.getElementById('wl-name').value.trim();
      const email = document.getElementById('wl-email').value.trim();
      const roleInput = document.querySelector('input[name="role"]:checked');

      if (!name) {
        errorEl.textContent = 'Please enter your full name.';
        errorEl.style.display = 'block';
        document.getElementById('wl-name').focus();
        return;
      }
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errorEl.textContent = 'Please enter a valid email address.';
        errorEl.style.display = 'block';
        document.getElementById('wl-email').focus();
        return;
      }
      if (!roleInput) {
        errorEl.textContent = 'Please select whether you are a customer or a driver.';
        errorEl.style.display = 'block';
        return;
      }

      // Show loading state
      const submitBtn = document.getElementById('wl-submit-btn');
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.7';
      document.getElementById('wl-submit-text').textContent = 'Submitting...';
      document.getElementById('wl-submit-icon').style.display = 'none';

      const payload = {
        name,
        email,
        phone: document.getElementById('wl-phone').value.trim(),
        role: roleInput.value,
        service_type: document.getElementById('wl-service-type').value,
        vehicle_type: document.getElementById('wl-vehicle-type').value,
        base_location: document.getElementById('wl-base-location').value.trim(),
        heard_from: document.getElementById('wl-heard-from').value,
        notes: document.getElementById('wl-notes').value.trim(),
      };

      try {
        const response = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const result = await response.json();

        if (result.success) {
          document.getElementById('waitlist-form-state').style.display = 'none';
          document.getElementById('waitlist-success-state').style.display = 'block';
        } else {
          errorEl.textContent = result.error || 'Something went wrong. Please try again.';
          errorEl.style.display = 'block';
          submitBtn.disabled = false;
          submitBtn.style.opacity = '1';
          document.getElementById('wl-submit-text').textContent = 'Join the Waitlist';
          document.getElementById('wl-submit-icon').style.display = 'inline';
        }
      } catch (err) {
        errorEl.textContent = 'Network error. Please check your connection and try again.';
        errorEl.style.display = 'block';
        submitBtn.disabled = false;
        submitBtn.style.opacity = '1';
        document.getElementById('wl-submit-text').textContent = 'Join the Waitlist';
        document.getElementById('wl-submit-icon').style.display = 'inline';
      }
    });
  </script>
</body>
</html>
