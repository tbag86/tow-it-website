---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}
const { title, description, canonical, ogImage = '/og-default.jpg' } = Astro.props;
const canonicalURL = canonical || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en-GB" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Tow It — AI Vehicle Transport UK</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content="index, follow" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} | Tow It`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Tow It" />
  <meta property="og:locale" content="en_GB" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | Tow It`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Tow It",
    "url": "https://towit.ai",
    "description": "AI-powered vehicle transport broker operating across the UK via WhatsApp",
    "email": "hello@towit.ai",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "GB"
    },
    "sameAs": [
      "https://wa.me/447700000000"
    ]
  }
  </script>
</head>
<body style="background-color:#080C14;color:#ffffff;font-family:'Inter',system-ui,sans-serif;">
  <nav style="position:fixed;top:0;left:0;right:0;z-index:50;background-color:rgba(8,12,20,0.95);backdrop-filter:blur(12px);border-bottom:1px solid #1A2540;">
    <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;">
      <div style="display:flex;align-items:center;justify-content:space-between;height:64px;">
        <a href="/" style="display:flex;align-items:center;text-decoration:none;">
          <img src="/logo.png" alt="Tow It Ai" style="height:48px;width:auto;" />
        </a>
        <div class="desktop-nav" style="display:flex;align-items:center;gap:24px;">
          <a href="/how-it-works" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;transition:color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">How It Works</a>
          <a href="/for-dealers" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">For Dealers</a>
          <a href="/auction-collections" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Auction Collections</a>
          <a href="/for-transport-companies" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Transport Companies</a>
          <a href="/pricing" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Pricing</a>
          <a href="/about" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">About</a>
          <a href="/contact" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Contact</a>
        </div>
        <div style="display:flex;align-items:center;gap:10px;">
          <!-- JOIN WAITLIST — desktop -->
          <button onclick="openWaitlistModal()" class="waitlist-nav-btn" style="display:inline-flex;align-items:center;gap:6px;background:#00C2FF;border:none;color:#080C14;font-size:0.85rem;font-weight:700;padding:9px 20px;border-radius:9999px;cursor:pointer;font-family:inherit;transition:all 0.2s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
            <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
            Join Waitlist
          </button>
          <button id="mobile-menu-btn" style="display:none;padding:8px;color:#8B96A8;background:none;border:none;cursor:pointer;" aria-label="Toggle menu">
            <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>
      </div>
    </div>
    <div id="mobile-menu" style="display:none;background-color:#0E1421;border-top:1px solid #1A2540;padding:16px 24px;">
      <div style="display:flex;flex-direction:column;gap:16px;">
        <a href="/how-it-works" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;">How It Works</a>
        <a href="/for-dealers" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;">For Dealers</a>
        <a href="/auction-collections" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;">Auction Collections</a>
        <a href="/for-transport-companies" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;">Transport Companies</a>
        <a href="/pricing" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;">Pricing</a>
        <a href="/about" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;">About</a>
        <a href="/contact" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;font-weight:500;">Contact</a>
        <!-- JOIN WAITLIST — mobile -->
        <button onclick="openWaitlistModal()" style="display:inline-flex;align-items:center;gap:8px;background:#00C2FF;border:none;color:#080C14;font-size:0.875rem;font-weight:700;padding:12px 22px;border-radius:9999px;cursor:pointer;font-family:inherit;width:fit-content;">
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
          Join the Waitlist
        </button>
      </div>
    </div>
  </nav>

  <main style="padding-top:64px;">
    <slot />
  </main>

  <!-- PRE-FOOTER WAITLIST CTA STRIP — appears on every page -->
  <section style="background:linear-gradient(135deg,#0E1421 0%,#141C2E 50%,#0E1421 100%);border-top:1px solid #1A2540;border-bottom:1px solid #1A2540;padding:56px 24px;text-align:center;position:relative;overflow:hidden;">
    <div style="position:absolute;top:0;left:50%;transform:translateX(-50%);width:500px;height:300px;background:radial-gradient(circle,rgba(0,194,255,0.06) 0%,transparent 70%);pointer-events:none;"></div>
    <div style="max-width:680px;margin:0 auto;position:relative;">
      <div style="display:inline-flex;align-items:center;gap:8px;background:#141C2E;border:1px solid #1A2540;border-radius:9999px;padding:5px 14px;margin-bottom:20px;">
        <span style="width:7px;height:7px;background:#00C2FF;border-radius:50%;display:inline-block;animation:pulse 2s infinite;"></span>
        <span style="color:#8B96A8;font-size:0.78rem;font-weight:500;">Launching Soon — Be First in Line</span>
      </div>
      <h2 style="font-size:clamp(1.6rem,4vw,2.4rem);font-weight:800;color:#ffffff;margin-bottom:14px;letter-spacing:-0.02em;">Get Early Access to Towit.ai</h2>
      <p style="color:#8B96A8;font-size:1rem;line-height:1.7;margin-bottom:32px;max-width:520px;margin-left:auto;margin-right:auto;">Whether you need vehicles transported or you're a driver looking for consistent work — join our waitlist now and be the first to know when we go live.</p>
      <div style="display:flex;flex-wrap:wrap;gap:14px;justify-content:center;">
        <button onclick="openWaitlistModal('customer')" style="display:inline-flex;align-items:center;gap:8px;background:#00C2FF;color:#080C14;font-size:0.95rem;font-weight:700;padding:13px 26px;border-radius:9999px;cursor:pointer;border:none;font-family:inherit;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          I Need a Vehicle Transported
        </button>
        <button onclick="openWaitlistModal('driver')" style="display:inline-flex;align-items:center;gap:8px;background:transparent;border:1.5px solid #00E88F;color:#00E88F;font-size:0.95rem;font-weight:700;padding:13px 26px;border-radius:9999px;cursor:pointer;font-family:inherit;transition:all 0.2s;" onmouseover="this.style.background='rgba(0,232,143,0.1)'" onmouseout="this.style.background='transparent'">
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10l2 0M3 6l3-3h8l3 3M13 16h3a1 1 0 001-1v-2.586a1 1 0 00-.293-.707l-2.414-2.414A1 1 0 0016.586 9H13v7z"/></svg>
          I'm a Driver / Transport Company
        </button>
      </div>
    </div>
  </section>

  <footer style="background-color:#0E1421;border-top:1px solid #1A2540;">
    <div style="max-width:1280px;margin:0 auto;padding:64px 24px;">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:40px;">
        <div>
          <a href="/" style="display:flex;align-items:center;text-decoration:none;margin-bottom:16px;">
            <img src="/logo.png" alt="Tow It Ai" style="height:46px;width:auto;" />
          </a>
          <p style="color:#8B96A8;font-size:0.875rem;line-height:1.6;margin-bottom:20px;">The UK's first AI-powered vehicle transport network. Instant quotes, vetted drivers, managed entirely via WhatsApp.</p>
          <button onclick="openWaitlistModal()" style="display:inline-flex;align-items:center;gap:8px;background:#00C2FF;border:none;color:#080C14;font-size:0.875rem;font-weight:700;padding:10px 20px;border-radius:9999px;cursor:pointer;font-family:inherit;">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
            Join the Waitlist
          </button>
        </div>
        <div>
          <h3 style="color:#ffffff;font-weight:600;font-size:0.875rem;margin-bottom:16px;">Services</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
            <li><a href="/how-it-works" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">How It Works</a></li>
            <li><a href="/pricing" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Pricing</a></li>
            <li><button onclick="openWaitlistModal()" style="background:none;border:none;color:#8B96A8;text-decoration:none;font-size:0.875rem;cursor:pointer;padding:0;font-family:inherit;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Join the Waitlist</button></li>
            <li><a href="/for-dealers" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Dealer Partnerships</a></li>
            <li><a href="/auction-collections" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Auction Collections</a></li>
            <li><a href="/international-car-transport" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">International Car Transport</a></li>
          </ul>
        </div>
        <div>
          <h3 style="color:#ffffff;font-weight:600;font-size:0.875rem;margin-bottom:16px;">Partners</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
            <li><a href="/for-transport-companies" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Transport Companies</a></li>
            <li><a href="/for-dealers" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Car Dealers</a></li>
            <li><a href="/for-transport-companies#register" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Driver Registration</a></li>
          </ul>
        </div>
        <div>
          <h3 style="color:#ffffff;font-weight:600;font-size:0.875rem;margin-bottom:16px;">Company</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
            <li><a href="/about" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">About Us</a></li>
            <li><a href="/contact" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Contact</a></li>
            <li><a href="/privacy" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Privacy Policy</a></li>
            <li><a href="/terms" style="color:#8B96A8;text-decoration:none;font-size:0.875rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#8B96A8'">Terms of Service</a></li>
          </ul>
        </div>
      </div>
      <div style="border-top:1px solid #1A2540;margin-top:48px;padding-top:32px;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:16px;">
        <p style="color:#4A5568;font-size:0.75rem;">© 2025 Tow It Limited. All rights reserved. Registered in England &amp; Wales.</p>
        <p style="color:#4A5568;font-size:0.75rem;">hello@towit.ai · <a href="https://towit.ai" style="color:#4A5568;" onmouseover="this.style.color='#8B96A8'" onmouseout="this.style.color='#4A5568'">towit.ai</a></p>
      </div>
    </div>
  </footer>

  <!-- =====================================================
       WAITLIST MODAL
  ====================================================== -->
  <div id="waitlist-overlay" onclick="handleOverlayClick(event)" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:200;overflow-y:auto;padding:24px 16px;">
    <div id="waitlist-modal" style="background:#141C2E;border:1px solid #1A2540;border-radius:20px;max-width:560px;width:100%;margin:0 auto;position:relative;overflow:hidden;" onclick="event.stopPropagation()">

      <!-- Modal Header -->
      <div style="background:linear-gradient(135deg,#0E1421,#141C2E);padding:28px 32px 24px;border-bottom:1px solid #1A2540;position:relative;">
        <button onclick="closeWaitlistModal()" style="position:absolute;top:20px;right:20px;background:#1A2540;border:none;color:#8B96A8;width:32px;height:32px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;line-height:1;" aria-label="Close">&times;</button>
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
          <div style="width:36px;height:36px;background:rgba(0,194,255,0.12);border-radius:10px;display:flex;align-items:center;justify-content:center;">
            <svg width="18" height="18" fill="none" stroke="#00C2FF" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          </div>
          <div>
            <h2 style="color:#ffffff;font-size:1.25rem;font-weight:700;margin:0;">Join the Waitlist</h2>
            <p style="color:#8B96A8;font-size:0.8rem;margin:2px 0 0;">Be first to access Towit.ai when we launch</p>
          </div>
        </div>
      </div>

      <!-- Form State -->
      <div id="waitlist-form-state" style="padding:28px 32px;">
        <form id="waitlist-form" novalidate>

          <!-- Name + Email row -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;" class="waitlist-2col">
            <div>
              <label style="display:block;color:#8B96A8;font-size:0.8rem;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em;">Full Name <span style="color:#00C2FF;">*</span></label>
              <input type="text" name="name" id="wl-name" required placeholder="e.g. James Smith" style="width:100%;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;color:#ffffff;font-size:0.9rem;padding:10px 14px;font-family:inherit;outline:none;box-sizing:border-box;" onfocus="this.style.borderColor='#00C2FF'" onblur="this.style.borderColor='#1A2540'" />
            </div>
            <div>
              <label style="display:block;color:#8B96A8;font-size:0.8rem;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em;">Email Address <span style="color:#00C2FF;">*</span></label>
              <input type="email" name="email" id="wl-email" required placeholder="you@example.com" style="width:100%;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;color:#ffffff;font-size:0.9rem;padding:10px 14px;font-family:inherit;outline:none;box-sizing:border-box;" onfocus="this.style.borderColor='#00C2FF'" onblur="this.style.borderColor='#1A2540'" />
            </div>
          </div>

          <!-- Phone -->
          <div style="margin-bottom:14px;">
            <label style="display:block;color:#8B96A8;font-size:0.8rem;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em;">WhatsApp / Mobile Number <span style="color:#4A5568;">(optional)</span></label>
            <input type="tel" name="phone" id="wl-phone" placeholder="+44 7700 000000" style="width:100%;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;color:#ffffff;font-size:0.9rem;padding:10px 14px;font-family:inherit;outline:none;box-sizing:border-box;" onfocus="this.style.borderColor='#00C2FF'" onblur="this.style.borderColor='#1A2540'" />
          </div>

          <!-- Role selector -->
          <div style="margin-bottom:14px;">
            <label style="display:block;color:#8B96A8;font-size:0.8rem;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em;">I am a... <span style="color:#00C2FF;">*</span></label>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
              <label id="role-customer-label" style="display:flex;align-items:center;gap:10px;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;padding:12px 14px;cursor:pointer;transition:border-color 0.2s;">
                <input type="radio" name="role" value="customer" id="wl-role-customer" style="display:none;" onchange="handleRoleChange(this.value)" />
                <div id="radio-customer" style="width:16px;height:16px;border-radius:50%;border:2px solid #4A5568;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all 0.2s;"></div>
                <div>
                  <div style="color:#ffffff;font-size:0.85rem;font-weight:600;">Customer</div>
                  <div style="color:#8B96A8;font-size:0.75rem;margin-top:1px;">I need a vehicle transported</div>
                </div>
              </label>
              <label id="role-driver-label" style="display:flex;align-items:center;gap:10px;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;padding:12px 14px;cursor:pointer;transition:border-color 0.2s;">
                <input type="radio" name="role" value="driver" id="wl-role-driver" style="display:none;" onchange="handleRoleChange(this.value)" />
                <div id="radio-driver" style="width:16px;height:16px;border-radius:50%;border:2px solid #4A5568;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all 0.2s;"></div>
                <div>
                  <div style="color:#ffffff;font-size:0.85rem;font-weight:600;">Driver / Company</div>
                  <div style="color:#8B96A8;font-size:0.75rem;margin-top:1px;">I want to deliver vehicles</div>
                </div>
              </label>
            </div>
          </div>

          <!-- CUSTOMER FIELDS -->
          <div id="customer-fields" style="display:none;margin-bottom:14px;">
            <label style="display:block;color:#8B96A8;font-size:0.8rem;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em;">What service are you interested in?</label>
            <select name="service_type" id="wl-service-type" style="width:100%;background:#0E1421;border:1.5px solid #1A2540;border-radius:10px;color:#ffffff;font-size:0.9rem;padding:10px 14px;font-family:inherit;outline:none;appearance:none;box-sizing:border-box;" onfocus="this.style.borderColor='#00C2FF'" onblur="this.style.borderColor='#1A2540'">
              <option value="">— Please select —</option>
              <option value="Private / personal car transport">Private / personal car transport</option>
              <option value="Dealer / trade transport">Dealer / trade transport</option>
              <option value="Auction collection">Auction collection</option>
              <option value="Fleet / multiple vehicles">Fleet / multiple vehicles</option>
              <option value="International transport">International transport</option>
              <option value="Not sure yet">Not sure yet</option>
            </select>
          </div>

          <!-- DRIVER FIELDS -->
          <div id="driver-fields" style="display:none;">
            <div style="margin-bottom:14px;">
